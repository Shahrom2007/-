#include <stdio.h>
#include <stdlib.h>

// Алгоритм Евклида (через остаток)
int gcd(int a, int b) {
    a = abs(a);
    b = abs(b);
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int main() {
    int x, y;
    printf("Введите два целых числа: ");
    scanf("%d %d", &x, &y);
    printf("НОД(%d, %d) = %d\n", x, y, gcd(x, y));
    return 0;
}
