def read_matrix(n):
    matrix = []

    print("Введите матрицу построчно:")

    for i in range(n):
        row = list(map(int, input().split()))

        if len(row) != n:
            print("Ошибка")
            return None

        matrix.append(row)

    return matrix


def is_symmetric(matrix, n):
    for i in range(n):
        for j in range(n):
            if matrix[i][j] != matrix[j][i]:
                return False
    return True


def has_loops(matrix, n):
    for i in range(n):
        if matrix[i][i] != 0:
            return True
    return False


def has_multiple_edges(matrix, n):
    for i in range(n):
        for j in range(n):
            if matrix[i][j] > 1:
                return True
    return False


def is_oriented(matrix, n):
    return not is_symmetric(matrix, n)


def dfs(v, matrix, visited, n):
    visited[v] = True

    for u in range(n):
        if matrix[v][u] != 0 and not visited[u]:
            dfs(u, matrix, visited, n)


def is_connected(matrix, n):
    visited = [False] * n

    dfs(0, matrix, visited, n)

    return all(visited)


def count_edges(matrix, n):
    edges = 0

    for i in range(n):
        for j in range(i + 1, n):
            if matrix[i][j] != 0:
                edges += 1

    return edges


def is_tree(matrix, n):
    if not is_connected(matrix, n):
        return False

    edges = count_edges(matrix, n)

    return edges == n - 1


n = int(input("Введите размер матрицы: "))

if n < 1 or n > 9:
    print("Ошибка")

else:

    matrix = read_matrix(n)

    if matrix is not None:

        correct = True

        for i in range(n):
            for j in range(n):

                if matrix[i][j] < 0:
                    print("Ошибка")
                    correct = False

        if correct:

            if is_symmetric(matrix, n):
                print("Матрица симметрична")
            else:
                print("Матрица несимметрична")

            if has_loops(matrix, n):
                print("Есть петли")
            else:
                print("Петель нет")

            if has_multiple_edges(matrix, n):
                print("Есть кратные рёбра")
            else:
                print("Кратных рёбер нет")

            if is_oriented(matrix, n):
                print("Ориентированный граф")
            else:
                print("Неориентированный граф")

            if not has_loops(matrix, n) and not has_multiple_edges(matrix, n):

                if is_connected(matrix, n):
                    print("Граф связный")
                else:
                    print("Граф несвязный")

                if not is_oriented(matrix, n):

                    if is_tree(matrix, n):
                        print("Граф является деревом")
                    else:
                        print("Граф не является деревом")
